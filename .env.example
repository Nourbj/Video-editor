# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3001

# Frontend (Vite)
VITE_API_BASE_URL=/api
VITE_APP_NAME=Video Editor

# Uploads
MAX_UPLOAD_MB=500

# yt-dlp
YTDLP_MAX_DURATION_SEC=600
YTDLP_FORMAT=bestvideo[height<=720][ext=mp4]+bestaudio[ext=m4a]/best[height<=720][ext=mp4]/best[ext=mp4]/best

# FFmpeg export
FFMPEG_CRF=23
FFMPEG_PRESET=fast

# Subtitles (defaults)
SUBTITLE_DEFAULT_SIZE=22
SUBTITLE_DEFAULT_COLOR=#ffffff
SUBTITLE_DEFAULT_POSITION=bottom

# Whisper (auto subtitles)
WHISPER_MODEL_DEFAULT=small
WHISPER_LANGUAGE_DEFAULT=auto
WHISPER_TIMEOUT_MS=1200000

